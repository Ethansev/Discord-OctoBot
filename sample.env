# ----- Required -----
DISCORD_TOKEN=
APPLICATION_ID=
OPENAI_API_KEY=

# ----- Optional core -----
NODE_ENV=development
# Channel name (not ID) the bot uses for announcements / Joel-kick notice
BOT_COMMANDS_CHANNEL=bot-commands
# Discord user ID that triggers the kick handler. Leave blank to disable.
JOEL_USER_ID=
# OpenAI model used by /chatgpt (and AI personality if enabled)
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_KEY=

# ----- Feature flags (true / false) -----
FF_AI_PERSONALITY=false
FF_TWITCH_ANNOUNCER=false
FF_MUSIC=false

# ----- AI personality -----
# The prompt lives in a file. Default: prompts/ai-personality.md
# AI_PERSONALITY_PROMPT_FILE=prompts/ai-personality.md
# Per-user cooldown in seconds (default 10)
# AI_PERSONALITY_COOLDOWN_SECONDS=10

# ----- Twitch announcer -----
# Required when FF_TWITCH_ANNOUNCER=true. App credentials from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Login name (lowercased), not display name
TWITCH_STREAMER_USERNAME=
# Discord channel ID (right-click channel → Copy ID with Developer Mode on)
TWITCH_ANNOUNCE_CHANNEL_ID=
# Default 60s. Minimum 30s to stay clear of Helix rate limits.
# TWITCH_POLL_INTERVAL_SECONDS=60
