# ----- Required -----
DISCORD_TOKEN=
APPLICATION_ID=
OPENAI_API_KEY=

# ----- Optional core -----
NODE_ENV=development
# Channel name (not ID) the bot uses for announcements / Joel-kick notice
BOT_COMMANDS_CHANNEL=bot-commands
# Discord user ID that triggers the kick handler. Leave blank to disable.
JOEL_USER_ID=
# OpenAI model used by /chatgpt (and AI personality if enabled)
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_KEY=

# ----- Feature flags (true / false) -----
FEATURE_AI_PERSONALITY=false
FEATURE_TWITCH_ANNOUNCER=false
FEATURE_MUSIC=false

# ----- AI personality (PR 3) -----
# AI_PERSONALITY_PROMPT=
# AI_PERSONALITY_COOLDOWN_SECONDS=10

# ----- Twitch announcer (PR 4) -----
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_STREAMER_USERNAME=
# TWITCH_ANNOUNCE_CHANNEL_ID=
# TWITCH_POLL_INTERVAL_SECONDS=60
